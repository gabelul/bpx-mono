{
  "name": "bpx-mono",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.base.json",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "version:patch": "npm version patch -ws --no-git-tag-version",
    "version:minor": "npm version minor -ws --no-git-tag-version",
    "version:major": "npm version major -ws --no-git-tag-version",
    "publish": "npm publish -ws --access public",
    "publish:dry": "npm publish -ws --access public --dry-run"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
